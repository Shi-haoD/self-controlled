# Self Controlled Docker 环境变量配置

# 数据库配置
POSTGRES_DB=work_management
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_PORT=5432

# 后端配置
DATABASE_URL=postgresql://admin:password123@postgres:5432/work_management
JWT_SECRET=your-super-secret-key-change-in-production-abc123xyz789
JWT_EXPIRE_MINUTES=1440
APP_ENV=production
DEBUG=false
BACKEND_PORT=8000
LOG_LEVEL=WARNING

# 前端配置
FRONTEND_PORT=8080
VITE_GLOB_API_URL=http://localhost:8000/api/v1

# 时区
TZ=Asia/Shanghai
